<%# locals: studies (Array/Relation of Study), active_id %>
<% active_id = local_assigns[:active_id] %>
<aside class="ps-sidebar">
  <div class="ps-sidebar-head">
    <div class="ps-sidebar-title">The Scriptorium</div>
    <button type="button" class="ps-new-study" data-action="new-study#open">
      <span class="plus">&#10010;</span>
      <span>New Study</span>
    </button>
  </div>

  <% unless authenticated? %>
    <div class="ps-sidebar-section">Your Studies</div>
    <div class="ps-study-list">
      <div class="ps-guest-note">
        <div>Studies you save will be kept here.</div>
        <div style="margin-top:8px;">
          <%= link_to "Sign in", new_session_path %> &middot; <%= link_to "Create account", new_registration_path %>
        </div>
      </div>
    </div>
  <% end %>

  <% if authenticated? && studies.blank? %>
    <div class="ps-sidebar-section">Studies</div>
    <div class="ps-study-list">
      <div class="ps-study-item" style="cursor: default;">
        <div class="meta" style="text-transform: none; letter-spacing: 0.02em; font-style: italic; font-family: 'EB Garamond', serif; font-size: 13px;">
          No studies yet. Begin a new one above.
        </div>
      </div>
    </div>
  <% elsif authenticated? %>
    <div class="ps-sidebar-section">Recent</div>
    <div class="ps-study-list">
      <% studies.each do |study| %>
        <div class="ps-study-item-wrap">
          <%= link_to study_path(study), class: "ps-study-item #{'is-active' if active_id == study.id}", style: "text-decoration:none;" do %>
            <div class="nm"><%= study.name %></div>
            <div class="meta"><%= pluralize(study.pane_count, "pane") %> &middot; <%= time_ago_in_words(study.last_opened_at || study.updated_at) %> ago</div>
          <% end %>
          <%= button_to study_path(study), method: :delete, class: "ps-study-del",
                title: "Delete study", form: { style: "display:contents;" },
                data: { turbo_confirm: "Delete “#{study.name}”? This cannot be undone." } do %>&#10005;<% end %>
        </div>
      <% end %>
    </div>
  <% end %>
</aside>
