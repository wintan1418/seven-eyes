<div class="ps-root"
     data-controller="book-browser ai-search search xref commentary lexicon shortcuts auth-gate new-study font-size presentation diff interlinear"
     data-font-size="<%= authenticated? ? current_user.font_size : 0 %>"
     data-font-size-url-value="<%= preferences_path %>"
     data-font-size-authenticated-value="<%= authenticated? %>">
  <%= render "topbar", study_name: @study.name, panes: @study.pane_count,
        sync: @study.sync_scroll, saved: true, study: @study %>
  <button type="button" class="ps-exit-presentation" data-action="presentation#exit"
          title="Exit focus mode (Esc)">
    <span>&#10005;</span> Exit Focus <span class="kbd">Esc</span>
  </button>
  <button type="button" class="ps-preach-enter" data-action="presentation#enterPreach"
          title="Preach mode — verse by verse, tap/swipe to advance">
    &#128272; Preach Mode
  </button>
  <button type="button" class="ps-preach-zone left"
          data-action="presentation#prev" aria-label="Previous verse"></button>
  <button type="button" class="ps-preach-zone right"
          data-action="presentation#next" aria-label="Next verse"></button>
  <div class="ps-preach-counter" data-preach-counter></div>

  <div class="ps-preach-controls">
    <div class="ps-preach-group">
      <span class="lbl">Group</span>
      <% (1..3).each do |n| %>
        <button type="button"
                class="<%= 'is-on' if n == 1 %>"
                data-action="presentation#setGroup"
                data-preach-group="<%= n %>"
                data-presentation-size-param="<%= n %>"><%= n %></button>
      <% end %>
    </div>
    <button type="button" class="ps-preach-parallel"
            data-preach-parallel
            data-action="presentation#toggleParallel"
            title="Show 2 translations side-by-side (P)">
      &#9783; Parallel
    </button>
    <button type="button" class="ps-preach-jump-btn"
            data-action="presentation#openJump"
            title="Jump to verse (G, then number)">
      G &#10142; verse
    </button>
  </div>

  <div class="ps-preach-jump" hidden>
    <span>Go to verse</span>
    <input type="number" min="1" inputmode="numeric"
           data-presentation-target="jumpInput"
           data-action="keydown.enter->presentation#jumpSubmit keydown.esc->presentation#cancelJump">
    <button type="button" data-action="presentation#jumpSubmit">Go</button>
  </div>
  <div class="ps-shell">
    <%= render "sidebar", studies: @studies, active_id: @study.id %>
    <main class="ps-workspace <%= workspace_cols_class(@study.pane_count) %>"
          data-controller="sync-scroll" data-sync-scroll-enabled-value="<%= @study.sync_scroll %>">
      <% @study.panes.each do |pane| %>
        <%= render "panes/pane", pane: pane %>
      <% end %>
    </main>
  </div>
  <%= render "studies/book_browser" %>
  <%= render "studies/ai_search", study: @study %>
  <%= render "studies/search", study: @study %>
  <%= render "studies/xref_drawer" %>
  <%= render "studies/commentary_drawer" %>
  <%= render "studies/lexicon_drawer" %>
  <%= render "studies/auth_prompt" unless authenticated? %>
  <%= render "studies/new_study_modal" %>
</div>
