<%# locals: study %>
<div class="ps-ai-drawer" data-ai-search-target="drawer">
  <div class="ps-book-backdrop" data-action="ai-search#close"></div>
  <aside class="ps-ai-panel">
    <div class="ps-drawer-head">
      <div class="ps-drawer-eyebrow">
        <span>&#10038; &nbsp; Find a Verse</span>
        <button class="close" type="button" data-action="ai-search#close">&#10005;</button>
      </div>
      <div class="ps-drawer-sub">Describe a thought or theme &mdash; I&rsquo;ll find matching Scripture.</div>
    </div>

    <%= form_with url: suggest_study_path(study), method: :get, data: { turbo_frame: "ai_results" } do %>
      <textarea name="q" rows="3" class="ps-ai-input" data-ai-search-target="input"
        placeholder="e.g. where does Paul say we&rsquo;re saved by grace, not by works?"></textarea>
      <button type="submit" class="btn primary" style="width:100%; margin-top:8px;">Search the Scriptures</button>
    <% end %>

    <%= turbo_frame_tag "ai_results", class: "ps-ai-results" do %>
      <div class="ps-ai-hint">Your suggestions will appear here.</div>
    <% end %>
  </aside>
</div>
