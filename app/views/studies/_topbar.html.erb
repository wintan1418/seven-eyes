<%# locals: study_name, panes (1..4), sync (bool), saved (bool), study (optional) %>
<% panes ||= 4 %>
<% study = local_assigns[:study] %>
<div class="ps-topbar">
  <div class="ps-brand">
    <%= link_to root_path, style: "text-decoration:none; color:inherit; display:flex; align-items:center; gap:10px;" do %>
      <span class="cross">&#9769;</span>
      <span>PARALLEL &middot; SCRIPTURE</span>
    <% end %>
  </div>
  <% if study %>
    <%= form_with url: study_path(study), method: :patch, data: { controller: "auto-submit" }, class: "ps-study-name" do |f| %>
      <span class="orn">&#10086;</span>
      <%= f.text_field :name, value: study.name, class: "ps-study-name-input", autocomplete: "off",
            "aria-label": "Study name", data: { action: "blur->auto-submit#submit" } %>
      <span class="pencil">&#9998;</span>
    <% end %>
  <% else %>
    <div class="ps-study-name">
      <span class="orn">&#10086;</span>
      <span><%= study_name %></span>
    </div>
  <% end %>
  <div class="ps-topbar-actions">
    <% if study %>
      <div class="ps-pane-picker" title="Pane count" data-tour="panes">
        <% (1..4).each do |n| %>
          <%= button_to n, study_path(study), method: :patch, params: { study: { pane_count: n } },
                class: (panes == n ? "is-on" : ""), form: { style: "display:contents;" } %>
        <% end %>
      </div>
      <button type="button" class="ps-tb-btn" data-action="search#open" data-tour="search">&#9906; Search</button>
      <button type="button" class="ps-tb-btn" data-action="ai-search#open" data-tour="find">&#10038; Find</button>
      <button type="button" class="ps-tb-btn" data-action="setlist#toggle"
              title="Preach queue — line up scriptures, songs and thoughts for the service">&#9835; Queue</button>
      <%= link_to sermon_study_path(study), class: "ps-tb-btn", data: { tour: "sermon" },
            style: "text-decoration:none;", title: "Compile this study as a printable sermon manuscript" do %>
        &#9998; Sermon
      <% end %>
      <% if authenticated? && study.user_id == current_user.id %>
        <button type="button" class="ps-tb-btn"
                data-controller="share"
                data-share-url-value="<%= share_study_path(study) %>"
                data-action="share#copy"
                title="Copy a read-only share link for this study">
          <span data-share-target="label">&#x1F517; Share</span>
        </button>
      <% end %>

      <div class="ps-view-menu" data-controller="view-menu">
        <button type="button" class="ps-tb-btn ps-view-trigger"
                data-action="view-menu#toggle" data-tour="view"
                title="Reading view options">
          &#9776; View
        </button>
        <div class="ps-view-panel" data-view-menu-target="panel" hidden>
          <div class="ps-view-section">
            <div class="ps-view-label">Text size</div>
            <div class="ps-font-size in-menu" title="Text size (for projection or large screens)">
              <span class="lbl">Aa</span>
              <input type="range" min="0" max="4" step="1" value="0"
                     data-font-size-target="slider"
                     data-action="input->font-size#change"
                     aria-label="Text size">
              <span class="level" data-font-size-target="level">S</span>
            </div>
          </div>
          <div class="ps-view-section">
            <div class="ps-view-label">Theme</div>
            <button type="button" class="ps-view-btn ps-theme-toggle"
                    data-action="theme#toggle">
              <span data-theme-target="icon">&#128367;</span>
              <span data-theme-target="label">Candle</span>
            </button>
          </div>
          <div class="ps-view-section">
            <div class="ps-view-label">Comparison</div>
            <button type="button" class="ps-view-btn"
                    data-action="diff#toggle" data-diff-target="button"
                    title="Highlight words that differ across translation panes">
              &#8644; Word diff
            </button>
            <button type="button" class="ps-view-btn"
                    data-action="interlinear#toggle" data-interlinear-target="button"
                    title="Show transliteration + Strong's beneath each tagged word (KJV)">
              &alpha; Lemma (Strong's)
            </button>
          </div>
          <div class="ps-view-section">
            <div class="ps-view-label">Sync</div>
            <%= button_to study_path(study), method: :patch, params: { study: { sync_scroll: !sync } },
                  class: "ps-view-btn #{'is-active' if sync}",
                  form: { style: "display:contents;" } do %>
              <span class="dot"></span> Sync scroll
            <% end %>
          </div>
        </div>
      </div>

      <%= link_to guide_path, class: "ps-tb-btn", data: { tour: "guide" },
            style: "text-decoration:none;", title: "Field guide — everything you can do here" do %>
        &#10070; Guide
      <% end %>
      <button type="button" class="ps-tb-btn ps-tb-btn-secondary" data-action="tour#start"
              title="Replay the quick tour">&#9737; Tour</button>

      <% if authenticated? %>
        <span class="ps-tb-btn is-active ps-saved-badge" style="cursor:default;">&#10003; Saved</span>
      <% else %>
        <button type="button" class="ps-tb-btn" data-action="auth-gate#open">&#9745; Save</button>
      <% end %>
    <% end %>
    <% if authenticated? %>
      <%= link_to "Plans", reading_plans_path, class: "ps-tb-btn", style: "text-decoration:none;" %>
      <% if current_user.guide_dismissed_at.present? %>
        <%= button_to "Show guide", restore_guide_path, method: :delete, class: "ps-tb-btn ps-tb-btn-secondary",
              form: { style: "display:contents;" } %>
      <% else %>
        <%= button_to "Hide guide", dismiss_guide_path, method: :post, class: "ps-tb-btn ps-tb-btn-secondary",
              form: { style: "display:contents;" } %>
      <% end %>
      <%= button_to "Sign out", session_path, method: :delete, class: "ps-tb-btn",
            form: { style: "display:contents;" } %>
    <% else %>
      <button type="button" class="ps-tb-btn ps-tb-btn-secondary" data-action="guide#toggle">
        <span data-guide-target="label">Hide guide</span>
      </button>
      <%= link_to "Sign in", new_session_path, class: "ps-tb-btn", style: "text-decoration:none;" %>
    <% end %>
  </div>
</div>
