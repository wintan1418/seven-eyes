<%# locals: study %>
<div class="ps-rabbi-host" data-rabbi-target="host">
  <div class="ps-book-backdrop" data-action="rabbi#close"></div>
  <aside class="ps-drawer ps-rabbi-drawer">
    <div class="ps-drawer-head">
      <div class="ps-drawer-eyebrow">
        <span>&#10018; &nbsp; The Rabbi</span>
        <button class="close" type="button" data-action="rabbi#close">&#10005;</button>
      </div>
      <div class="ps-drawer-sub">
        Highlight words in the text, then &ldquo;Ask the Rabbi&rdquo; &mdash; explained in
        full context, never beyond Scripture.
      </div>
    </div>

    <%# Hidden form lives OUTSIDE the result frame so it survives each ask.
        The rabbi controller fills these inputs from the current selection and
        submits, loading the answer into the rabbi_drawer frame. %>
    <%= form_with url: rabbi_study_path(study), method: :get,
          data: { turbo_frame: "rabbi_drawer", rabbi_target: "form" }, class: "ps-rabbi-form" do %>
      <input type="hidden" name="verse_id" data-rabbi-target="verseId">
      <input type="hidden" name="q" data-rabbi-target="query">
    <% end %>

    <%= turbo_frame_tag "rabbi_drawer", class: "ps-rabbi-body", data: { rabbi_target: "frame" } do %>
      <div class="ps-ai-hint">
        Select a phrase in any verse and choose <em>&#10018; Rabbi</em> from the popover.
        The whole chapter and its cross-references are weighed before a word is said.
      </div>
    <% end %>
  </aside>
</div>
