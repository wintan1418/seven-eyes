<div class="ps-xref-host ps-commentary-host" data-commentary-target="host">
  <div class="ps-book-backdrop" data-action="commentary#close"></div>
  <aside class="ps-drawer">
    <%= turbo_frame_tag "commentary_drawer" do %>
      <div class="ps-drawer-head">
        <div class="ps-drawer-eyebrow">
          <span>&#128220; &nbsp; Commentary</span>
          <button class="close" type="button" data-action="commentary#close">&#10005;</button>
        </div>
        <div class="ps-drawer-sub">Open a chapter, then read the exposition here.</div>
      </div>
    <% end %>
  </aside>
</div>
