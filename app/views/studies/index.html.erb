<div class="ps-root" data-controller="new-study">
  <%= render "topbar", study_name: "The Scriptorium", panes: 4, sync: false, saved: true %>
  <div class="ps-shell">
    <%= render "sidebar", studies: @studies %>
    <main class="ps-workspace is-doc" style="grid-template-columns: 1fr;">
      <div class="ps-welcome">
        <div class="eyebrow">&#9769; &nbsp; A Quiet Desk For The Word &nbsp; &#9769;</div>
        <% if authenticated? %>
          <h1>Welcome back.</h1>
        <% else %>
          <h1>Parallel Scripture</h1>
        <% end %>
        <div class="rule-orn">
          <span class="line"></span>
          <span>&#10086;</span>
          <span class="line"></span>
        </div>
        <div class="verse-of-day">
          <% if @verse_of_day %>
            &ldquo;<%= @verse_of_day.text %>&rdquo;
            <span class="ref"><%= @verse_of_day.reference_label %> &middot; <%= @verse_of_day.translation_code %></span>
          <% else %>
            &ldquo;Open thou mine eyes, that I may behold wondrous things out of thy law.&rdquo;
            <span class="ref">Psalm 119:18 &middot; KJV</span>
          <% end %>
        </div>
        <div class="cta-row">
          <button type="button" class="cta" data-action="new-study#open">&#10010; &nbsp; Begin a New Study</button>
          <% if (resume = @studies.first) %>
            <%= link_to "↻  Resume #{truncate(resume.name, length: 28)}", study_path(resume),
                  class: "cta secondary", style: "text-decoration:none;" %>
          <% end %>
          <% if authenticated? %>
            <%= link_to "&#10070; Reading Plans".html_safe, reading_plans_path,
                  class: "cta secondary", style: "text-decoration:none;" %>
          <% end %>
        </div>

        <% if @active_plan && @plan_today %>
          <div class="ps-today-panel">
            <div class="ps-today-label">Today &middot; <%= @active_plan.name %> &middot; day <%= @plan_today.day_number %></div>
            <div class="ps-today-refs"><%= @plan_today.refs.presence || "No passages set for today." %></div>
            <div class="ps-today-cta">
              <% if @plan_today.refs.present? %>
                <%= link_to "Begin today's reading", open_today_reading_plan_path(@active_plan), class: "cta" %>
              <% end %>
              <%= link_to "Open plan", reading_plan_path(@active_plan), class: "cta secondary", style: "text-decoration:none;" %>
              <span class="ps-today-streak">streak <%= @active_plan.current_streak %></span>
            </div>
          </div>
        <% elsif authenticated? && @studies.empty? %>
          <%# gentle nudge for new users %>
          <div class="ps-today-panel ps-today-panel--soft">
            <div class="ps-today-label">A Daily Rhythm</div>
            <div class="ps-today-refs">Build a reading plan to keep your time in the Word steady — pace a single book, the whole New Testament, the year-long Bible, or your own custom path.</div>
            <div class="ps-today-cta">
              <%= link_to "Create a Reading Plan", new_reading_plan_path, class: "cta" %>
            </div>
          </div>
        <% end %>

        <% if @show_guide %>
          <%= render "studies/guide" %>
        <% end %>
        <div style="margin-top: 38px; font-family: 'Cinzel', serif; font-size: 10px; letter-spacing: 0.22em; color: var(--sepia-mute); text-transform: uppercase;">
          <span>kjv &middot; asv &middot; bsb &middot; web &middot; darby &middot; ylt</span>
          <span style="margin: 0 10px; color: var(--gold);">&middot;</span>
          <span>tsk cross-references &middot; seeded locally</span>
        </div>
      </div>
    </main>
  </div>
  <%= render "studies/new_study_modal" %>
</div>
