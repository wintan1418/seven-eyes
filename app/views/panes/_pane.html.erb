<%= turbo_frame_tag pane.frame_id, class: "ps-pane", data: { controller: "pane reader memorize" } do %>
  <% content = pane.content %>

  <%= form_with model: [ pane.study, pane ], method: :patch, data: { controller: "auto-submit" } do |f| %>
    <div class="ps-pane-head">
      <div class="ps-pane-index"><%= pane_numeral(pane.position) %></div>
      <%= f.text_field :reference, value: pane.reference,
            placeholder: "Type a reference…", autocomplete: "off", spellcheck: "false",
            autocapitalize: "none", autocorrect: "off", inputmode: "search", enterkeyhint: "go",
            data: { action: "keydown.enter->auto-submit#submit" },
            class: "ps-search#{' empty' if pane.empty?}" %>
      <%= f.select :translation_id, translation_options(pane.effective_translation&.id),
            {}, class: "ps-trans-select", id: "pane_#{pane.id}_translation",
            "aria-label": "Translation", data: { action: "change->auto-submit#submit" } %>
      <% if content.ok? %>
        <%= link_to "\u{1F4DC}", commentary_study_path(pane.study, osis: content.book.osis_code, chapter: content.parsed.chapter),
              class: "ps-pane-tool", title: "Commentary",
              data: { turbo_frame: "commentary_drawer", action: "commentary#open" } %>
        <button type="button" class="ps-pane-tool" title="Read aloud"
                data-action="reader#toggle" data-reader-target="button">&#9658;</button>
        <button type="button" class="ps-pane-tool" title="Memorize mode"
                data-action="memorize#toggle" data-memorize-target="button">&#9680;</button>
        <button type="button" class="ps-pane-tool <%= "has-notes" if pane.notes.present? %>"
                title="Notes" data-action="pane#toggleNotes">&#9998;</button>
        <button type="button" class="ps-pane-tool" title="Focus this pane (presentation mode)"
                data-action="presentation#enter">&#9974;</button>
      <% end %>
      <button type="button" class="ps-pane-tool" title="Browse books"
              data-action="book-browser#open" data-pane-id="<%= pane.id %>">&#128214;</button>
      <%# Implicit-submit fallback: ensures the touch keyboard's Go button
          submits the form (mobile browsers ignore Enter when a form has no
          submit control). %>
      <button type="submit" tabindex="-1" aria-hidden="true"
              style="position:absolute;left:-9999px;width:1px;height:1px;opacity:0;">Go</button>
    </div>
  <% end %>

  <% if content.ok? %>
    <div class="ps-verses">
      <% prev_ref = neighbor_reference(content.book, content.parsed.chapter, :prev) %>
      <% next_ref = neighbor_reference(content.book, content.parsed.chapter, :next) %>
      <div class="ref-title">
        <% if prev_ref %>
          <%= button_to "‹", study_pane_path(pane.study, pane), method: :patch,
                params: { pane: { reference: prev_ref } },
                class: "ps-ch-nav prev", title: "Previous chapter (#{prev_ref})",
                form: { data: { turbo_frame: pane.frame_id }, style: "display:contents;" } %>
        <% end %>
        <span><%= reference_title(content.book, content.parsed.chapter) %></span>
        <span class="tag">&middot; <%= content.translation.name %></span>
        <% if next_ref %>
          <%= button_to "›", study_pane_path(pane.study, pane), method: :patch,
                params: { pane: { reference: next_ref } },
                class: "ps-ch-nav next", title: "Next chapter (#{next_ref})",
                form: { data: { turbo_frame: pane.frame_id }, style: "display:contents;" } %>
        <% end %>
      </div>
      <div class="rule"></div>
      <% highlights_by_verse = authenticated? ? current_user.highlights.where(verse_id: content.verses.map(&:id)).group_by(&:verse_id) : {} %>
      <div class="ps-verse-body" data-controller="highlighter" data-action="click->memorize#reveal">
        <% content.verses.each_with_index do |verse, i| %>
          <%= scripture_verse(verse, study: pane.study, book: content.book,
                highlights: highlights_by_verse[verse.id] || [],
                dropcap: i.zero? && verse.verse_number == 1) %>
        <% end %>
      </div>
    </div>

    <%= form_with url: study_pane_path(pane.study, pane), method: :patch, class: "ps-notes-form",
          data: { controller: "notes", turbo: false, pane_target: "notes" } do %>
      <div class="ps-notes">
        <div class="ps-notes-head">
          <span>Notes <span class="saving" data-notes-target="status">&mdash; <%= pane.notes.present? ? "Saved" : "auto-saves as you write" %></span></span>
          <button type="button" class="ps-notes-close" title="Close notes" data-action="pane#toggleNotes">&#10005;</button>
        </div>
        <textarea name="pane[notes]" class="ps-notes-area" rows="4"
                  placeholder="Write a thought, an outline, a cross-reference to remember…"
                  data-action="input->notes#schedule"><%= pane.notes %></textarea>
        <input type="hidden" name="autosave" value="1">
      </div>
    <% end %>
  <% elsif content.error == :empty %>
    <div class="ps-pane-empty">
      <div class="orn">&#10086;</div>
      <div class="lead">Pane <%= pane_numeral(pane.position) %> stands ready</div>
      <div class="hint">Type a reference &mdash; <em>Jn 3:16, Rom 5, 1 Cor 13</em> &mdash; to summon the text.</div>
      <div style="display:flex; gap:6px; margin-top:6px;">
        <span class="kbd">&#8984; K</span>
        <span class="kbd"><%= pane.position + 1 %></span>
      </div>
    </div>
  <% else %>
    <div class="ps-pane-empty">
      <div class="orn">&#9888;</div>
      <div class="lead">
        <% case content.error %>
        <% when :not_found %>
          Not found in <%= content.translation&.code %>
        <% else %>
          That reference could not be read
        <% end %>
      </div>
      <div class="hint">
        <% if content.error == :not_found %>
          &ldquo;<%= pane.reference %>&rdquo; isn&rsquo;t in this translation. Try another reference or version.
        <% else %>
          Try a form like <em>John 3:16</em>, <em>Rom 5</em>, or <em>1 Cor 13:1-13</em>.
        <% end %>
      </div>
    </div>
  <% end %>
<% end %>
